# GroupPulse Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=GroupPulse
ENVIRONMENT=production  # development, staging, production
DEBUG=false
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# =============================================================================
# Telegram Bot
# =============================================================================
# Get your bot token from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Optional: Webhook configuration (leave empty for polling)
BOT_WEBHOOK_URL=
BOT_WEBHOOK_SECRET=

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://grouppulse:your_strong_password@postgres:5432/grouppulse

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false  # Set to true to log all SQL queries (debugging only)

# =============================================================================
# Redis
# =============================================================================
# Format: redis://[:password@]host:port/db
REDIS_URL=redis://:your_redis_password@redis:6379/0
REDIS_MAX_CONNECTIONS=50

# =============================================================================
# Security & Encryption
# =============================================================================
# JWT for future API authentication (optional for now)
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
# Global system rate limit (messages/second)
GLOBAL_RATE_LIMIT=100

# Per-account rate limit (messages/second)
# Telegram allows ~20-30 msg/sec, we use conservative 20
ACCOUNT_RATE_LIMIT=20

# Per-destination rate limit (messages/second)
# Anti-spam protection for destination groups
DESTINATION_RATE_LIMIT=5

# =============================================================================
# Performance Settings
# =============================================================================
# Maximum number of Telegram accounts to manage
MAX_WORKERS=10

# Maximum concurrent forwarding operations
MAX_CONCURRENT_FORWARDS=100

# Batch size for database operations
MESSAGE_BATCH_SIZE=50

# =============================================================================
# Data Retention
# =============================================================================
# How long to keep message logs (days)
MESSAGE_LOG_RETENTION_DAYS=30

# How long to keep system metrics (days)
METRICS_RETENTION_DAYS=7

# =============================================================================
# Monitoring (Optional)
# =============================================================================
# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=

# Prometheus metrics port
PROMETHEUS_PORT=8001

# =============================================================================
# Docker-specific (used by docker-compose.yml)
# =============================================================================
POSTGRES_USER=grouppulse
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=grouppulse

REDIS_PASSWORD=your_redis_password
